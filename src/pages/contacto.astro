---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import bannerImage from "../assets/banners/panoramico-cusco.webp";

const contactInfo = [
  { icon: "ion:call-outline", label: "Teléfono", value: "+51 900 086 730", href: "tel:+51900086730" },
  { icon: "ion:mail-outline", label: "Email", value: "info@farawayexplorers.com", href: "mailto:info@farawayexplorers.com" },
  { icon: "ion:location-outline", label: "Oficina principal", value: "Calle Bolivar 220, Cusco, Perú", href: "#" },
  { icon: "ion:time-outline", label: "Horario", value: "Lunes a Sábado: 8:00 AM - 6:00 PM", href: null },
];

const socials = [
  { icon: "ion:logo-facebook", label: "Facebook", href: "#" },
  { icon: "ion:logo-instagram", label: "Instagram", href: "#" },
  { icon: "ion:logo-tiktok", label: "TikTok", href: "#" },
  { icon: "ion:logo-youtube", label: "YouTube", href: "#" },
];
---

<Layout title="Contáctanos | Far Away Explorers">
  <div class="contact-page">

    <!-- Hero -->
    <section class="contact-hero">
      <div class="contact-hero__bg" aria-hidden="true">
        <img src={bannerImage.src} alt="" class="contact-hero__bg-img" />
        <div class="contact-hero__bg-overlay"></div>
        <div class="contact-hero__bg-dots"></div>
      </div>
      <div class="container">
        <div class="contact-hero__inner">
          <p class="contact-hero__eyebrow">Hablemos</p>
          <h1 class="contact-hero__title">Contáctanos</h1>
          <p class="contact-hero__desc">
            ¿Tienes preguntas o quieres planear tu próximo viaje? Estamos aquí para ayudarte.
          </p>
        </div>
      </div>
    </section>

    <!-- Breadcrumb -->
    <div class="contact-topbar">
      <div class="container">
        <nav class="contact-topbar__breadcrumb" aria-label="Breadcrumb">
          <a href="/" class="contact-topbar__breadcrumb-link">Inicio</a>
          <Icon name="ion:chevron-forward" class="contact-topbar__breadcrumb-sep" aria-hidden="true" />
          <span class="contact-topbar__breadcrumb-current">Contacto</span>
        </nav>
      </div>
    </div>

    <!-- Main content -->
    <section class="contact-main">
      <div class="container">
        <div class="contact-main__grid">

          <!-- Info -->
          <div class="contact-info">
            <div class="contact-info__header">
              <p class="contact-info__eyebrow">Información de contacto</p>
              <h2 class="contact-info__title">¿Cómo nos encuentras?</h2>
              <p class="contact-info__desc">
                Puedes comunicarte con nosotros por cualquiera de estos medios. Responderemos lo antes posible.
              </p>
            </div>

            <div class="contact-info__items">
              {contactInfo.map((item) => (
                <div class="contact-info__item">
                  <div class="contact-info__item-icon-wrap">
                    <Icon name={item.icon} class="contact-info__item-icon" aria-hidden="true" />
                  </div>
                  <div class="contact-info__item-text">
                    <span class="contact-info__item-label">{item.label}</span>
                    {item.href ? (
                      <a href={item.href} class="contact-info__item-value contact-info__item-value--link">{item.value}</a>
                    ) : (
                      <span class="contact-info__item-value">{item.value}</span>
                    )}
                  </div>
                </div>
              ))}
            </div>

            <div class="contact-info__social">
              <p class="contact-info__social-label">Síguenos en redes:</p>
              <div class="contact-info__social-links">
                {socials.map((s) => (
                  <a href={s.href} class="contact-info__social-btn" aria-label={s.label}>
                    <Icon name={s.icon} class="contact-info__social-icon" aria-hidden="true" />
                  </a>
                ))}
              </div>
            </div>
          </div>

          <!-- Form -->
          <div class="contact-form-wrap">
            <h2 class="contact-form__title">Envíanos un mensaje</h2>
            <form class="contact-form" action="#" method="POST">
              <div class="contact-form__row">
                <div class="contact-form__field">
                  <label for="contact-name" class="contact-form__label">Nombre completo</label>
                  <input type="text" id="contact-name" name="name" class="contact-form__input" placeholder="Tu nombre" required />
                </div>
                <div class="contact-form__field">
                  <label for="contact-email" class="contact-form__label">Correo electrónico</label>
                  <input type="email" id="contact-email" name="email" class="contact-form__input" placeholder="tu@email.com" required />
                </div>
              </div>
              <div class="contact-form__field">
                <label for="contact-phone" class="contact-form__label">Teléfono (opcional)</label>
                <input type="tel" id="contact-phone" name="phone" class="contact-form__input" placeholder="+51 999 999 999" />
              </div>
              <div class="contact-form__field">
                <label for="contact-subject" class="contact-form__label">Asunto</label>
                <input type="text" id="contact-subject" name="subject" class="contact-form__input" placeholder="¿En qué podemos ayudarte?" required />
              </div>
              <div class="contact-form__field">
                <label for="contact-message" class="contact-form__label">Mensaje</label>
                <textarea id="contact-message" name="message" class="contact-form__input contact-form__textarea" placeholder="Cuéntanos sobre tu viaje ideal..." rows="5" required></textarea>
              </div>
              <button type="submit" class="contact-form__submit">
                <Icon name="ion:send-outline" class="contact-form__submit-icon" aria-hidden="true" />
                Enviar mensaje
              </button>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- Map -->
    <section class="contact-map">
      <div class="container">
        <div class="contact-map__header">
          <p class="contact-map__eyebrow">Ubicación</p>
          <h2 class="contact-map__title">Visítanos en Cusco</h2>
        </div>
      </div>
      <div class="contact-map__embed">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3879.087921707077!2d-71.93532199962338!3d-13.530195607117935!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x916e7f4f6fa1cde3%3A0x946d4feaac38815f!2sC.%20Bolivar%20220%2C%20Cusco%2008004!5e0!3m2!1ses!2spe!4v1772854528758!5m2!1ses!2spe"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Far Away Explorers en Cusco"
        ></iframe>
      </div>
    </section>

  </div>
</Layout>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins' as *;

  // ═══════════════════════════════════════════════════════════════════════════
  // HERO
  // ═══════════════════════════════════════════════════════════════════════════
  .contact-hero {
    position: relative;
    min-height: 320px;
    display: flex;
    align-items: center;
    overflow: hidden;

    @include md { min-height: 380px; }
  }

  .contact-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .contact-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .contact-hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.7) 100%
    );
  }

  .contact-hero__bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba($color-white, 0.08) 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.5;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding-block: 4rem;
    max-width: 640px;
    margin-inline: auto;
  }

  .contact-hero__eyebrow {
    font-size: $font-size-sm;
    font-weight: $font-weight-bold;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: $color-primary;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    &::before,
    &::after {
      content: '';
      display: inline-block;
      width: 1.5rem;
      height: 2px;
      background-color: $color-primary;
      border-radius: 2px;
    }
  }

  .contact-hero__title {
    font-size: 2rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $color-white;

    @include md { font-size: 2.75rem; }
  }

  .contact-hero__desc {
    font-size: $font-size-base;
    line-height: 1.7;
    color: rgba($color-white, 0.85);
    max-width: 520px;

    @include md { font-size: $font-size-lg; }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // TOPBAR / BREADCRUMB
  // ═══════════════════════════════════════════════════════════════════════════
  .contact-topbar {
    border-bottom: 1px solid #e8e8e8;
    background-color: $color-white;
  }

  .contact-topbar__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding-block: 0.875rem;
    font-size: $font-size-sm;
  }

  .contact-topbar__breadcrumb-link {
    color: $color-text-muted;
    transition: color 0.25s ease;
    &:hover { color: $color-primary; }
  }

  .contact-topbar__breadcrumb-sep {
    font-size: 0.7rem;
    color: $color-text-muted;
  }

  .contact-topbar__breadcrumb-current {
    color: $color-primary;
    font-weight: $font-weight-semibold;
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MAIN SECTION
  // ═══════════════════════════════════════════════════════════════════════════
  .contact-main {
    padding-block: 3rem;
    @include md { padding-block: 4rem; }
  }

  .contact-main__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;

    @include lg {
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // CONTACT INFO
  // ═══════════════════════════════════════════════════════════════════════════
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-info__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-info__eyebrow {
    @include eyebrow;
    text-transform: uppercase;
  }

  .contact-info__title {
    font-size: 1.5rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $color-text-dark;

    @include md { font-size: 1.875rem; }
  }

  .contact-info__desc {
    font-size: $font-size-base;
    line-height: 1.7;
    color: #444;
  }

  .contact-info__items {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-info__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact-info__item-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: rgba($color-primary, 0.1);
    flex-shrink: 0;
  }

  .contact-info__item-icon {
    font-size: 1.25rem;
    color: $color-primary;
  }

  .contact-info__item-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding-top: 0.25rem;
  }

  .contact-info__item-label {
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    color: $color-text-dark;
  }

  .contact-info__item-value {
    font-size: $font-size-base;
    color: #444;
    line-height: 1.5;

    &--link {
      transition: color 0.25s ease;
      &:hover { color: $color-primary; }
    }
  }

  // Social
  .contact-info__social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid #e8e8e8;
  }

  .contact-info__social-label {
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $color-text-dark;
  }

  .contact-info__social-links {
    display: flex;
    gap: 0.625rem;
  }

  .contact-info__social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: $color-primary;
    border-radius: 50%;
    border: 2px solid transparent;
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      transform 0.2s ease,
      box-shadow 0.25s ease;

    &:hover {
      background-color: $color-white;
      border-color: $color-primary;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba($color-primary, 0.25);
    }
  }

  .contact-info__social-icon {
    font-size: 1.1rem;
    color: $color-white;
    transition: color 0.25s ease;

    .contact-info__social-btn:hover & {
      color: $color-primary;
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // FORM
  // ═══════════════════════════════════════════════════════════════════════════
  .contact-form-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: #faf8f5;
    border: 1px solid #eee;
    border-radius: 10px;
    padding: 2rem 1.5rem;

    @include md { padding: 2.5rem; }
  }

  .contact-form__title {
    font-size: 1.25rem;
    font-weight: $font-weight-bold;
    color: $color-text-dark;

    @include md { font-size: 1.5rem; }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;

    @include sm { grid-template-columns: repeat(2, 1fr); }
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-form__label {
    font-size: $font-size-sm;
    font-weight: $font-weight-medium;
    color: $color-text-dark;
  }

  .contact-form__input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: $font-size-base;
    font-family: inherit;
    color: $color-text-dark;
    background-color: $color-white;
    border: 1.5px solid #ddd;
    border-radius: 6px;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;

    &::placeholder {
      color: #aaa;
    }

    &:focus {
      outline: none;
      border-color: $color-primary;
      box-shadow: 0 0 0 3px rgba($color-primary, 0.1);
    }
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    align-self: flex-start;
    background-color: $color-primary;
    color: $color-white;
    border: 2px solid $color-primary;
    border-radius: 6px;
    padding: 0.75rem 2rem;
    font-size: $font-size-base;
    font-family: inherit;
    font-weight: $font-weight-semibold;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition:
      background-color 0.25s ease,
      color 0.25s ease,
      transform 0.2s ease,
      box-shadow 0.25s ease;

    &:hover {
      background-color: $color-white;
      color: $color-primary;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba($color-primary, 0.28);
    }
  }

  .contact-form__submit-icon {
    font-size: 1rem;
    transition: transform 0.2s ease;
    .contact-form__submit:hover & { transform: translateX(3px); }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MAP
  // ═══════════════════════════════════════════════════════════════════════════
  .contact-map {
    padding-top: 2rem;
    padding-bottom: 0;
  }

  .contact-map__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .contact-map__eyebrow {
    @include eyebrow;
    text-transform: uppercase;
  }

  .contact-map__title {
    font-size: 1.5rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $color-text-dark;

    @include md { font-size: 1.875rem; }
  }

  .contact-map__embed {
    width: 100%;
    line-height: 0;

    iframe {
      width: 100%;
      height: 350px;

      @include md { height: 420px; }
    }
  }
</style>
