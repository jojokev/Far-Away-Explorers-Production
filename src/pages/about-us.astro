---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import bannerImage from "../assets/banners/panoramico-cusco.webp";

const values = [
  { icon: "ion:heart-outline", title: "Pasion", desc: "Amamos lo que hacemos y eso se refleja en cada experiencia que diseñamos para ti." },
  { icon: "ion:shield-checkmark-outline", title: "Confianza", desc: "Operamos con transparencia y compromiso para que viajes con total tranquilidad." },
  { icon: "ion:people-outline", title: "Cercanía", desc: "Somos un equipo local que conoce cada rincón del Perú y te acompaña en todo momento." },
  { icon: "ion:sparkles-outline", title: "Autenticidad", desc: "Creamos rutas únicas que te conectan con la cultura y la naturaleza de forma genuina." },
];

const stats = [
  { number: "500+", label: "Viajeros felices" },
  { number: "50+", label: "Tours disponibles" },
  { number: "7", label: "Destinos en Perú" },
  { number: "5", label: "Años de experiencia" },
];
---

<Layout title="Sobre Nosotros | Far Away Explorers">
  <div class="about-page">

    <!-- Hero -->
    <section class="about-hero">
      <div class="about-hero__bg" aria-hidden="true">
        <img src={bannerImage.src} alt="" class="about-hero__bg-img" />
        <div class="about-hero__bg-overlay"></div>
        <div class="about-hero__bg-dots"></div>
      </div>
      <div class="container">
        <div class="about-hero__inner">
          <p class="about-hero__eyebrow">Conócenos</p>
          <h1 class="about-hero__title">Sobre Nosotros</h1>
          <p class="about-hero__desc">
            Somos una agencia de viajes local con sede en Cusco, dedicada a crear experiencias auténticas e inolvidables por el Perú.
          </p>
        </div>
      </div>
    </section>

    <!-- Breadcrumb -->
    <div class="about-topbar">
      <div class="container">
        <nav class="about-topbar__breadcrumb" aria-label="Breadcrumb">
          <a href="/" class="about-topbar__breadcrumb-link">Inicio</a>
          <Icon name="ion:chevron-forward" class="about-topbar__breadcrumb-sep" aria-hidden="true" />
          <span class="about-topbar__breadcrumb-current">Sobre Nosotros</span>
        </nav>
      </div>
    </div>

    <!-- Historia -->
    <section class="about-story">
      <div class="container">
        <div class="about-story__inner">
          <div class="about-story__content">
            <p class="about-story__eyebrow">FAR AWAY EXPLORERS</p>
            <h2 class="about-story__title">Nuestra Historia</h2>
            <p class="about-story__text">
              Far Away Explorers nació de la pasión por compartir la riqueza cultural y natural del Perú con el mundo. Desde nuestros inicios en la ciudad imperial del Cusco, hemos trabajado para ofrecer experiencias de viaje que van más allá de lo convencional.
            </p>
            <p class="about-story__text">
              Nuestro equipo está formado por guías locales expertos, apasionados por su tierra y comprometidos con brindar un servicio de calidad. Cada ruta que diseñamos busca conectar al viajero con la esencia del Perú: su historia milenaria, sus paisajes imponentes y la calidez de su gente.
            </p>
            <p class="about-story__text">
              Creemos que viajar es mucho más que visitar lugares; es vivir historias, crear recuerdos y transformar perspectivas. Por eso, en Far Away Explorers cuidamos cada detalle para que tu aventura sea única, segura y memorable.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Valores -->
    <section class="about-values">
      <div class="container">
        <div class="about-values__header">
          <p class="about-values__eyebrow">Lo que nos define</p>
          <h2 class="about-values__title">Nuestros Valores</h2>
        </div>
        <div class="about-values__grid">
          {values.map((v) => (
            <div class="about-values__card">
              <div class="about-values__card-icon-wrap">
                <Icon name={v.icon} class="about-values__card-icon" aria-hidden="true" />
              </div>
              <h3 class="about-values__card-title">{v.title}</h3>
              <p class="about-values__card-desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="about-stats">
      <div class="container">
        <div class="about-stats__grid">
          {stats.map((s) => (
            <div class="about-stats__item">
              <span class="about-stats__number">{s.number}</span>
              <span class="about-stats__label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <div class="container">
        <div class="about-cta__inner">
          <h2 class="about-cta__title">¿Listo para tu próxima aventura?</h2>
          <p class="about-cta__desc">
            Contáctanos y diseñemos juntos el viaje de tus sueños por el Perú.
          </p>
          <a href="/contacto" class="about-cta__btn">
            <Icon name="ion:mail-outline" class="about-cta__btn-icon" aria-hidden="true" />
            Contáctanos
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins' as *;

  // ═══════════════════════════════════════════════════════════════════════════
  // HERO
  // ═══════════════════════════════════════════════════════════════════════════
  .about-hero {
    position: relative;
    min-height: 320px;
    display: flex;
    align-items: center;
    overflow: hidden;

    @include md { min-height: 380px; }
  }

  .about-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .about-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.7) 100%
    );
  }

  .about-hero__bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba($color-white, 0.08) 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.5;
  }

  .about-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding-block: 4rem;
    max-width: 640px;
    margin-inline: auto;
  }

  .about-hero__eyebrow {
    font-size: $font-size-sm;
    font-weight: $font-weight-bold;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: $color-primary;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    &::before,
    &::after {
      content: '';
      display: inline-block;
      width: 1.5rem;
      height: 2px;
      background-color: $color-primary;
      border-radius: 2px;
    }
  }

  .about-hero__title {
    font-size: 2rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $color-white;

    @include md { font-size: 2.75rem; }
  }

  .about-hero__desc {
    font-size: $font-size-base;
    line-height: 1.7;
    color: rgba($color-white, 0.85);
    max-width: 520px;

    @include md { font-size: $font-size-lg; }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // TOPBAR / BREADCRUMB
  // ═══════════════════════════════════════════════════════════════════════════
  .about-topbar {
    border-bottom: 1px solid #e8e8e8;
    background-color: $color-white;
  }

  .about-topbar__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding-block: 0.875rem;
    font-size: $font-size-sm;
  }

  .about-topbar__breadcrumb-link {
    color: $color-text-muted;
    transition: color 0.25s ease;
    &:hover { color: $color-primary; }
  }

  .about-topbar__breadcrumb-sep {
    font-size: 0.7rem;
    color: $color-text-muted;
  }

  .about-topbar__breadcrumb-current {
    color: $color-primary;
    font-weight: $font-weight-semibold;
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // STORY
  // ═══════════════════════════════════════════════════════════════════════════
  .about-story {
    padding-block: 3rem;
    @include md { padding-block: 4rem; }
  }

  .about-story__inner {
    max-width: 780px;
    margin-inline: auto;
  }

  .about-story__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-story__eyebrow {
    font-size: $font-size-base;
    font-weight: $font-weight-bold;
    letter-spacing: 0.12em;
    color: $color-primary;
    text-align: center;
  }

  .about-story__title {
    font-size: 1.5rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    letter-spacing: 0.06em;
    color: $color-text-dark;
    text-align: center;
    text-transform: uppercase;

    @include md { font-size: 1.875rem; }
  }

  .about-story__text {
    font-size: $font-size-base;
    line-height: 1.7;
    letter-spacing: 0.2px;
    color: #444;
    text-align: center;
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // VALUES
  // ═══════════════════════════════════════════════════════════════════════════
  .about-values {
    padding-block: 3rem;
    background-color: #faf8f5;
    @include md { padding-block: 4rem; }
  }

  .about-values__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .about-values__eyebrow {
    @include eyebrow;
    text-transform: uppercase;
  }

  .about-values__title {
    font-size: 1.5rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    letter-spacing: 0.06em;
    color: $color-text-dark;
    text-transform: uppercase;

    @include md { font-size: 1.875rem; }
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @include sm { grid-template-columns: repeat(2, 1fr); }
    @include lg { grid-template-columns: repeat(4, 1fr); }
  }

  .about-values__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 2rem 1.25rem;
    background-color: $color-white;
    border-radius: 8px;
    border: 1px solid #eee;
    transition: transform 0.25s ease, box-shadow 0.25s ease;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba($color-primary, 0.1);
    }
  }

  .about-values__card-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: rgba($color-primary, 0.1);
    transition: background-color 0.25s ease;

    .about-values__card:hover & {
      background-color: $color-primary;
    }
  }

  .about-values__card-icon {
    font-size: 1.5rem;
    color: $color-primary;
    transition: color 0.25s ease;

    .about-values__card:hover & {
      color: $color-white;
    }
  }

  .about-values__card-title {
    font-size: $font-size-base;
    font-weight: $font-weight-semibold;
    color: $color-text-dark;
  }

  .about-values__card-desc {
    font-size: $font-size-sm;
    line-height: 1.6;
    color: $color-text-muted;
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // STATS
  // ═══════════════════════════════════════════════════════════════════════════
  .about-stats {
    padding-block: 3rem;
    @include md { padding-block: 4rem; }
  }

  .about-stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 700px;
    margin-inline: auto;

    @include md { grid-template-columns: repeat(4, 1fr); }
  }

  .about-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.5rem 1rem;
  }

  .about-stats__number {
    font-size: 2rem;
    font-weight: $font-weight-bold;
    color: $color-primary;
    line-height: 1;

    @include md { font-size: 2.5rem; }
  }

  .about-stats__label {
    font-size: $font-size-sm;
    font-weight: $font-weight-medium;
    color: $color-text-muted;
    text-align: center;
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // CTA
  // ═══════════════════════════════════════════════════════════════════════════
  .about-cta {
    padding-block: 3rem;
    background-color: #faf8f5;
    @include md { padding-block: 4rem; }
  }

  .about-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    max-width: 520px;
    margin-inline: auto;
  }

  .about-cta__title {
    font-size: 1.5rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $color-text-dark;

    @include md { font-size: 1.875rem; }
  }

  .about-cta__desc {
    font-size: $font-size-base;
    line-height: 1.7;
    color: #444;
  }

  .about-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: $color-primary;
    color: $color-white;
    border: 2px solid $color-primary;
    border-radius: 6px;
    padding: 0.75rem 2rem;
    font-size: $font-size-base;
    font-weight: $font-weight-semibold;
    letter-spacing: 0.02em;
    transition:
      background-color 0.25s ease,
      color 0.25s ease,
      transform 0.2s ease,
      box-shadow 0.25s ease;

    &:hover {
      background-color: $color-white;
      color: $color-primary;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba($color-primary, 0.28);
    }
  }

  .about-cta__btn-icon {
    font-size: 1.1rem;
    transition: transform 0.2s ease;
    .about-cta__btn:hover & { transform: scale(1.1); }
  }
</style>
