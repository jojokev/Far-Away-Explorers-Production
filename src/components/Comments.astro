---
import prevIcon from "../assets/icons/Vector-3.png";
import nextIcon from "../assets/icons/Vector-4.png";
import score from "../assets/icons/Score.png";
import tripadvisor from "../assets/icons/Tripadvisor.png";
import { Icon } from "astro-icon/components";

const navPrevIcon      = prevIcon.src;
const navNextIcon      = nextIcon.src;
const reviewScoreImage = score.src;
const tripadvisorIcon  = tripadvisor.src;

const reviews = [
  {
    comment: "It was a rewarding experience, expectations were met above expectations leaving the illusion of returning to visit Peru. Thank you to Kevin for his kind attention and excellent service.",
    user:    "Juan Carlos P",
    tag:     "Couples",
    date:    "Written March 1, 2026",
    avatar:  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/1a/f6/ef/32/default-avatar-2020-12.jpg?w=100&h=100&s=1",
  },
  {
    comment: "The experience of the trip was the best, the tourist advice, the friendliness and courtesy of the group of people who attended us especially Kevin , was far above what was expected. They took it upon themselves to make this trip unforgettable, which we will keep in memory. We'll be back soon!",
    user:    "Martha G",
    tag:     "Couples",
    date:    "Written March 1, 2026",
    avatar:  "https://dynamic-media-cdn.tripadvisor.com/media/photo-l/01/2a/fd/94/avatar.jpg?w=100&h=100&s=1",
  },
  {
    comment: "Unique service, personalized pending the smallest detail. Kevin I want an excellent person working tirelessly to make everything work for us and well. Super recommended we travel from Colombia with everything organized by Kevin!!! I don't miss anything.",
    user:    "Pedro C",
    tag:     "Solo",
    date:    "Written February 28, 2026",
    avatar:  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/1a/f6/ef/9c/default-avatar-2020-14.jpg?w=100&h=100&s=1",
  },
  {
    comment: "One of the best experiences we have had as a family, Kevin is a great person who helped us a lot throughout our stay, always attentive and willing to help us in any situation.",
    user:    "Fredy R",
    tag:     "Solo",
    date:    "Written February 27, 2026",
    avatar:  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/1a/f6/ef/9c/default-avatar-2020-14.jpg?w=100&h=100&s=1",
  },
  {
    comment: "I loved the service, the attention 10/10 treated me like family thank you for the nice experience, I recommend it more than a trip is a new experience!.",
    user:    "Dreamer51700917596",
    tag:     "Friends",
    date:    "Written February 27, 2026",
    avatar:  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/1a/f6/f2/b8/default-avatar-2020-26.jpg?w=100&h=100&s=1",
  },
];
---

<section class="reviews">
  <div class="container">
    <div class="reviews__inner">

      <!-- ── Header ───────────────────────────────── -->
      <div class="reviews__header">
        <p class="reviews__eyebrow">DESTINOS</p>
        <h2 class="reviews__title">HAPPY TRAVELERS</h2>
      </div>

      <!-- ── Slider ───────────────────────────────── -->
      <div class="reviews__slider-wrapper">

        <button type="button" class="reviews__nav reviews__nav--prev comentarios-button-prev" aria-label="Anterior">
          <img src={navPrevIcon} alt="" class="reviews__nav-icon" />
        </button>
        <button type="button" class="reviews__nav reviews__nav--next comentarios-button-next" aria-label="Siguiente">
          <img src={navNextIcon} alt="" class="reviews__nav-icon" />
        </button>

        <div class="swiper comentarios-swiper">
          <div class="swiper-wrapper">
            {reviews.map((review) => (
              <article class="swiper-slide reviews__card">

                <span class="reviews__quote" aria-hidden="true">&ldquo;</span>

                <!-- ← wrapper con scroll cuando el texto excede el límite -->
                <div class="reviews__card-comment-wrapper">
                  <p class="reviews__card-comment">{review.comment}</p>
                </div>

                <div class="reviews__card-author">
                  <img
                    src={review.avatar}
                    alt={review.user}
                    class="reviews__card-avatar"
                    loading="lazy"
                  />
                  <div class="reviews__card-author-info">
                    <h3 class="reviews__card-name">{review.user}</h3>
                    <img
                      src={reviewScoreImage}
                      alt="Puntuación 5 estrellas"
                      class="reviews__card-score"
                      loading="lazy"
                    />
                    <div class="reviews__card-tag">
                      <Icon name="ion:pricetag" class="reviews__card-tag-icon" aria-hidden="true" />
                      <span>{review.tag}</span>
                    </div>
                  </div>
                </div>

                <div class="reviews__card-footer">
                  <div class="reviews__card-date">
                    <Icon name="ion:calendar" class="reviews__card-date-icon" aria-hidden="true" />
                    <span>{review.date}</span>
                  </div>
                  <img
                    src={tripadvisorIcon}
                    alt="Tripadvisor"
                    class="reviews__card-tripadvisor"
                    loading="lazy"
                  />
                </div>

              </article>
            ))}
          </div>
        </div>

        <div class="reviews__pagination-wrapper">
          <div class="comentarios-pagination" aria-label="Paginacion de comentarios"></div>
        </div>

      </div>

      <!-- ── CTA ──────────────────────────────────── -->
      <a href="https://www.tripadvisor.com/Attraction_Review-g294314-d34235732-Reviews-Far_Away_Explorers-Cusco_Cusco_Region.html" target="_blank" class="reviews__cta">
        View All Reviews
        <Icon name="ion:arrow-forward" class="reviews__cta-icon" aria-hidden="true" />
      </a>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins'   as *;

  // ─── Variables locales ──────────────────────────────────────────────────────
  $reviews-color-text:        #15252d;
  $reviews-color-muted:       #666;
  $reviews-color-border:      rgba(221, 221, 221, 0.45);
  $reviews-color-tripadv:     #00852f;
  $reviews-avatar-size:       4rem;
  $reviews-tripadv-size:      2.5rem;
  $reviews-score-h:           14px;
  $reviews-score-w:           78px;
  $reviews-shadow-card:       0 2px 12px rgba(0, 0, 0, 0.06);
  $reviews-shadow-hover:      0 10px 28px rgba(0, 0, 0, 0.10);
  // ← altura máxima del área de comentario antes de activar scroll
  $reviews-comment-max-h:     7.5rem;  // ~4 líneas

  // ─── Section ────────────────────────────────────────────────────────────────
  .reviews {
    padding-block: 2.5rem;
    @include md { padding-block: 2.5rem; }
  }

  // ─── Inner ──────────────────────────────────────────────────────────────────
  .reviews__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    width: 100%;
    text-align: center;
    font-style: normal;
    padding-block: 2rem;
  }

  // ─── Header ─────────────────────────────────────────────────────────────────
  .reviews__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }

  .reviews__eyebrow {
    font-size: $font-size-sm;
    font-weight: $font-weight-bold;
    letter-spacing: 0.14em;
    color: $color-primary;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;

    &::before,
    &::after {
      content: '';
      display: inline-block;
      width: 2rem;
      height: 2px;
      background-color: $color-primary;
      border-radius: 2px;
    }
  }

  .reviews__title {
    font-size: 1.875rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    letter-spacing: 0.04em;
    color: $color-text-dark;
    @include md { font-size: 2rem; }
  }

  // ─── Slider wrapper ─────────────────────────────────────────────────────────
  .reviews__slider-wrapper {
    position: relative;
    width: 100%;
    padding-inline: 2rem;
    @include md { padding-inline: 3rem; }
  }

  // ─── Botones nav ────────────────────────────────────────────────────────────
  .reviews__nav {
    display: none;
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    background-color: $color-white;
    border: 1.5px solid rgba($color-primary, 0.25);
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition:
      background-color 0.2s ease,
      border-color     0.2s ease,
      transform        0.2s ease,
      box-shadow       0.2s ease;

    &:hover {
      background-color: $color-primary;
      border-color: $color-primary;
      transform: translateY(-50%) scale(1.08);
      box-shadow: 0 4px 14px rgba($color-primary, 0.3);

      .reviews__nav-icon { filter: brightness(0) invert(1); }
    }

    &--prev { left: 0; }
    &--next { right: 0; }

    @include md { display: flex; }
  }

  .reviews__nav-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: filter 0.2s ease;
  }

  // ─── Card ───────────────────────────────────────────────────────────────────
  .reviews__card {
    position: relative;
    display: flex;
    flex-direction: column;
    // ← altura fija: todas las cards miden igual independiente del contenido
    height: 100%;
    min-height: 320px;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid $reviews-color-border;
    background-color: $color-white;
    text-align: left;
    box-shadow: $reviews-shadow-card;
    transition:
      box-shadow   0.3s ease,
      transform    0.3s ease,
      border-color 0.3s ease;

    &:hover {
      box-shadow: $reviews-shadow-hover;
      transform: translateY(-3px);
      border-color: rgba($color-primary, 0.2);
    }
  }

  // ─── Comillas decorativas ────────────────────────────────────────────────────
  .reviews__quote {
    position: absolute;
    top: 0.5rem;
    right: 1.25rem;
    font-size: 5rem;
    line-height: 1;
    color: rgba($color-primary, 0.08);
    font-family: Georgia, serif;
    pointer-events: none;
    user-select: none;
  }

  // ─── Wrapper scrollable del comentario ──────────────────────────────────────
  .reviews__card-comment-wrapper {
    position: relative;
    max-height: $reviews-comment-max-h;
    overflow-y: auto;
    // ← scroll sutil sin scrollbar visible en webkit
    scrollbar-width: thin;
    scrollbar-color: rgba($color-primary, 0.25) transparent;

    &::-webkit-scrollbar {
      width: 3px;
    }

    &::-webkit-scrollbar-track {
      background: transparent;
    }

    &::-webkit-scrollbar-thumb {
      background-color: rgba($color-primary, 0.3);
      border-radius: 99px;

      &:hover { background-color: rgba($color-primary, 0.55); }
    }

    // ← fade inferior cuando el contenido hace scroll
    &::after {
      content: '';
      position: sticky;
      bottom: 0;
      left: 0;
      display: block;
      width: 100%;
      height: 1.5rem;
      background: linear-gradient(to top, $color-white, transparent);
      pointer-events: none;
    }
  }

  // ─── Comentario ─────────────────────────────────────────────────────────────
  .reviews__card-comment {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: $reviews-color-text;
    position: relative;
    z-index: 1;
    // ← sin margin para no interferir con el sticky fade
    margin: 0;
    padding-right: 0.25rem;  // ← espacio para el scrollbar
  }

  // ─── Autor ──────────────────────────────────────────────────────────────────
  .reviews__card-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1rem;
    margin-top: auto;        // ← siempre pegado al fondo de la card
    border-top: 1px solid rgba(221, 221, 221, 0.6);
    flex-shrink: 0;
  }

  .reviews__card-avatar {
    width: $reviews-avatar-size;
    height: $reviews-avatar-size;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid rgba($color-primary, 0.2);
  }

  .reviews__card-author-info {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .reviews__card-name {
    font-size: 1.125rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $reviews-color-text;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reviews__card-score {
    height: $reviews-score-h;
    width: $reviews-score-w;
    object-fit: contain;
  }

  .reviews__card-tag {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: $font-size-sm;
    color: $reviews-color-muted;
  }

  .reviews__card-tag-icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  // ─── Footer ─────────────────────────────────────────────────────────────────
  .reviews__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.75rem;
    flex-shrink: 0;
  }

  .reviews__card-date {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: $font-size-sm;
    color: $reviews-color-muted;
  }

  .reviews__card-date-icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  .reviews__card-tripadvisor {
    width: $reviews-tripadv-size;
    height: $reviews-tripadv-size;
    object-fit: contain;
    transition: transform 0.25s ease, opacity 0.25s ease;

    .reviews__card:hover & {
      transform: scale(1.08);
      opacity: 0.9;
    }
  }

  // ─── Paginación ─────────────────────────────────────────────────────────────
  .reviews__pagination-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 1.75rem;
  }

  .comentarios-pagination {
    display: flex;
    gap: 0.375rem;
    justify-content: center;
    align-items: center;
  }

  :global(.comentarios-pagination .comentarios-pagination-bullet) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    border: 1.5px solid $reviews-color-tripadv;
    background: transparent;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      width            0.25s ease,
      border-color     0.2s ease,
      box-shadow       0.2s ease,
      transform        0.2s ease;

    &:hover {
      background-color: rgba($reviews-color-tripadv, 0.4);
      transform: scale(1.15);
    }

    &:focus-visible {
      outline: 2px solid rgba($reviews-color-tripadv, 0.45);
      outline-offset: 2px;
    }
  }

  :global(.comentarios-pagination .comentarios-pagination-bullet-active) {
    background-color: $reviews-color-tripadv;
    border-color: $reviews-color-tripadv;
    width: 20px;
    border-radius: 9999px;
    box-shadow: 0 4px 10px rgba($reviews-color-tripadv, 0.3);
  }

  :global(.comentarios-nav-disabled) {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  // ─── CTA ────────────────────────────────────────────────────────────────────
  .reviews__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background-color: $reviews-color-tripadv;
    color: $color-white;
    border: 2px solid $reviews-color-tripadv;
    border-radius: 8px;
    padding: 0.625rem 1.5rem;
    font-size: $font-size-base;
    font-weight: $font-weight-semibold;
    letter-spacing: 0.02em;
    transition:
      background-color 0.25s ease,
      color            0.25s ease,
      transform        0.2s ease,
      box-shadow       0.25s ease;

    &:hover {
      background-color: $color-white;
      color: $reviews-color-tripadv;
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba($reviews-color-tripadv, 0.28);
    }
  }

  .reviews__cta-icon {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform 0.2s ease;

    .reviews__cta:hover & { transform: translateX(3px); }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  new Swiper(".comentarios-swiper", {
    modules: [Navigation, Pagination],
    slidesPerView: 1.1,
    spaceBetween: 12,
    pagination: {
      el: ".comentarios-pagination",
      clickable: true,
      bulletClass: "swiper-pagination-bullet comentarios-pagination-bullet",
      bulletActiveClass: "swiper-pagination-bullet-active comentarios-pagination-bullet-active",
    },
    navigation: {
      prevEl: ".comentarios-button-prev",
      nextEl: ".comentarios-button-next",
      disabledClass: "comentarios-nav-disabled",
    },
    breakpoints: {
      640:  { slidesPerView: 2, spaceBetween: 16 },
      1024: { slidesPerView: 3, spaceBetween: 16 },
    },
  });
</script>
