---
import logoAsset from "../assets/logo-far-away-2.webp";
import avatar from "../assets/icons/metodos-pago.webp";
import reclamaciones from "../assets/icons/reclamaciones.webp";
import esnna from "../assets/icons/esnna.webp";
import { Icon } from "astro-icon/components";

const logo = logoAsset.src;
const protectedBadge = esnna.src;
const claimsBook = reclamaciones.src;
const paymentMethods = avatar.src;

const destinations = [
  { text: "Arequipa", link: "/arequipa" },
  { text: "Puno", link: "/puno" },
  { text: "Cusco", link: "/cusco" },
  { text: "Nazca", link: "/nazca" },
  { text: "Ica", link: "/ica" },
  { text: "Lima", link: "/lima" },
];

const aboutLinks = [
  { text: "Sobre nosotros", link: "/about-us" },
  { text: "Contactanos", link: "/contacto" },
  { text: "Nuestros Blogs", link: "/blog" },
  { text: "Terminos y condiciones", link: "/terminos-y-condiciones" },
  { text: "Politica de Datos", link: "/politica-de-datos" },
];
const packages = [
  { text: "Huacachina, Machupicchu, Isla Uros Puno", link: "/paquetes/huacachina-machupicchu-isla-uros-puno" },
  { text: "Huacachina, MachupicLima, Isla Palomino", link: "/paquetes/huacachina-machupiclima-isla-palomino" },
  { text: "Lima, Ica, Huacachina, Machupicchu", link: "/paquetes/lima-ica-huacachina-machupicchu" },
  { text: "Senderismo en la Naturaleza", link: "/paquetes/senderismo-en-la-naturaleza" },
  { text: "Trekking en las Montanas", link: "/paquetes/trekking-en-las-montanas" },
  { text: "Cusco, Machupicchu, Laguna Humantay", link: "/paquetes/cusco-machupicchu-laguna-humantay" },
];
---

<footer class="footer">
  <section class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <div class="footer__brand">
          <div class="footer__info">
            <img src={logo} alt="Far Away Explorers" class="footer__logo" />
            <p class="footer__meta">
              <span class="footer__meta-label">Nombre comercial:</span>
              <span> FAR AWAY EXPLORERS SAC</span>
            </p>
            <p class="footer__meta">
              <span class="footer__meta-label">RUC:</span>
              <span> 20615539865</span>
            </p>
          </div>

          <div class="footer__contact">
            <a href="mailto:info@farawayexplorers.com" class="footer__contact-item">
              <Icon name="ion:mail-outline" class="footer__contact-icon" aria-hidden="true" />
              info@farawayexplorers.com
            </a>
            <a href="tel:+51900086730" class="footer__contact-item">
              <Icon name="ion:call-outline" class="footer__contact-icon" aria-hidden="true" />
              +51 900 086 730
            </a>
            <a href="#" class="footer__contact-item footer__contact-item--align-top">
              <Icon name="ion:location-outline" class="footer__contact-icon footer__contact-icon--location" aria-hidden="true" />
              <span>
                <span class="footer__meta-label">Oficina principal:</span>
                <span> Calle Bolivar 220 Cusco</span>
              </span>
            </a>
          </div>

          <div class="footer__social">
            <p class="footer__social-title">Síguenos :</p>
            <div class="footer__social-links">
              <a href="#" aria-label="TikTok" class="footer__social-btn">
                <Icon name="ion:logo-tiktok" class="footer__social-icon" aria-hidden="true" />
              </a>
              <a href="#" aria-label="Facebook" class="footer__social-btn">
                <Icon name="ion:logo-facebook" class="footer__social-icon" aria-hidden="true" />
              </a>
              <a href="#" aria-label="YouTube" class="footer__social-btn">
                <Icon name="ion:logo-youtube" class="footer__social-icon" aria-hidden="true" />
              </a>
              <a href="https://www.tripadvisor.com/Attraction_Review-g294314-d34235732-Reviews-Far_Away_Explorers-Cusco_Cusco_Region.html" target="_blank" aria-label="TripAdvisor" class="footer__social-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 36" fill="none" class="footer__social-tripadvisor" aria-hidden="true">
                  <path d="M32.4566 14.4819L34.8261 12.1187H29.5715C26.941 10.4715 23.7641 9.51221 20.3283 9.51221C16.8969 9.51221 13.7289 10.4736 11.1027 12.1187H5.83496L8.20445 14.4819C6.75207 15.6966 5.84157 17.4463 5.84157 19.3891C5.84157 23.0555 9.08429 26.028 13.0839 26.028C14.9839 26.028 16.7149 25.3563 18.0072 24.2582L20.3284 26.575L22.6496 24.2602C23.9419 25.3583 25.6707 26.028 27.5706 26.028C31.5702 26.028 34.8173 23.0555 34.8173 19.3891C34.8195 17.4443 33.909 15.6946 32.4566 14.4819ZM13.086 23.8821C10.3787 23.8821 8.18475 21.871 8.18475 19.3891C8.18475 16.9073 10.3787 14.8961 13.086 14.8961C15.7934 14.8961 17.9873 16.9073 17.9873 19.3891C17.9873 21.871 15.7934 23.8821 13.086 23.8821ZM20.3305 19.2584C20.3305 16.3019 17.9852 13.7639 14.8895 12.6798C16.5635 12.0382 18.3998 11.6823 20.3283 11.6823C22.2568 11.6823 24.0953 12.0382 25.7694 12.6798C22.6759 13.7659 20.3305 16.302 20.3305 19.2584ZM27.5728 23.8821C24.8655 23.8821 22.6715 21.871 22.6715 19.3891C22.6715 16.9073 24.8655 14.8961 27.5728 14.8961C30.2802 14.8961 32.4741 16.9073 32.4741 19.3891C32.4741 21.871 30.2802 23.8821 27.5728 23.8821ZM27.5728 17.032C26.1533 17.032 25.0037 18.0859 25.0037 19.3871C25.0037 20.6883 26.1533 21.7422 27.5728 21.7422C28.9923 21.7422 30.142 20.6883 30.142 19.3871C30.1419 18.0879 28.9923 17.032 27.5728 17.032ZM15.6552 19.3891C15.6552 20.6903 14.5055 21.7442 13.086 21.7442C11.6666 21.7442 10.5169 20.6903 10.5169 19.3891C10.5169 18.0879 11.6666 17.034 13.086 17.034C14.5055 17.032 15.6552 18.0879 15.6552 19.3891Z" fill="currentColor"></path>
                </svg>
              </a>
              <a href="#" aria-label="Instagram" class="footer__social-btn">
                <Icon name="ion:logo-instagram" class="footer__social-icon" aria-hidden="true" />
              </a>
            </div>
          </div>

          <div class="footer__badges">
            <a href="https://wp.farawayexplorers.com/wp-content/uploads/2026/03/ESNNA.pdf" target="_blank" aria-label="ESNNA"><img src={protectedBadge} alt="ProtÃ©genos" class="footer__badge" /></a>
            <img src={claimsBook} alt="Libro de Reclamaciones" class="footer__badge footer__badge--claims" />
          </div>
        </div>

        <div class="footer__menu">
          <h2 class="footer__menu-title">MENU</h2>
          <div class="footer__menu-grid">
            <div class="footer__menu-col">
              <div class="footer__menu-group">
                <h3 class="footer__menu-heading">Destinos</h3>
                <ul class="footer__menu-list">
                  {destinations.map((item) => (
                    <li><a href={item.link} class="footer__menu-link">{item.text}</a></li>
                  ))}
                </ul>
              </div>
              <div class="footer__menu-group">
                <h3 class="footer__menu-heading">Quienes somos</h3>
                <ul class="footer__menu-list">
                  {aboutLinks.map((item) => (
                    <li><a href={item.link} class="footer__menu-link">{item.text}</a></li>
                  ))}
                </ul>
              </div>
            </div>
            <div class="footer__menu-col">
              <div class="footer__menu-group">
                <h3 class="footer__menu-heading">Paquetes</h3>
                <ul class="footer__menu-list">
                  {packages.map((item) => (
                    <li><a href={item.link} class="footer__menu-link">{item.text}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="footer__bottom">
    <div class="container">
      <div class="footer__bottom-inner">
        <p class="footer__copyright">
          copyright © 2024 Far Away Explorers todos los derechos
        </p>
        <div class="footer__payments">
          <p class="footer__payments-label">Metodos de pago:</p>
          <img src={paymentMethods} alt="Metodos de pago" class="footer__payments-img" />
        </div>
      </div>
    </div>
  </div>
</footer>

<a
  href="https://wa.me/51900086730?text=Hola%2C%20equipo%20de%20Far%20Away%20Explorers.%20Quisiera%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20tours%20y%20paquetes%2C%20por%20favor."
  class="footer__whatsapp-float"
  aria-label="Escríbenos por WhatsApp"
  target="_blank"
  rel="noopener noreferrer"
>
  <Icon name="ion:logo-whatsapp" class="footer__whatsapp-float-icon" aria-hidden="true" />
</a>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins' as *;


  // Footer base
  .footer {
    border-top: 2px solid $color-primary;
    background-color: $color-white;
  }

  // Main section 
  .footer__main {
    padding-block: 2.5rem;
    @include md { padding-block: 3.5rem; }
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    @include lg {
      grid-template-columns: 1fr 1.1fr;
      gap: 4rem;
    }
  }

  // Brand 
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .footer__info {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer__logo {
    height: 5rem;
    width: 151px;
    object-fit: contain;
    margin-bottom: 0.25rem;
  }

  // Meta texto 
  .footer__meta {
    font-size: $font-size-base;
    letter-spacing: 0.2px;
    color: $color-text-dark;
    line-height: 1.6;
  }

  .footer__meta-label {
    font-weight: $font-weight-semibold; 
    color: #000;
  }

  //Contacto
  .footer__contact {
    display: flex;
    flex-direction: column;
    border-top: 1px solid #e8e8e8;   
  }

  .footer__contact-item {
    display: flex;
    align-items: center;
    gap: $spacing-1;
    padding-block: 0.6rem;
    border-bottom: 1px dashed #ddd;
    font-size: $font-size-base;
    letter-spacing: 0.2px;
    color: $color-text-dark;
    transition: color 0.25s ease, padding-left 0.25s ease;

    //  hover: desplazamiento + color primario
    &:hover {
      color: $color-primary;
      padding-left: 0.375rem;

      .footer__contact-icon {
        transform: scale(1.15);
      }
    }

    &--align-top { align-items: flex-start; }
  }

  .footer__contact-icon {
    color: $color-primary;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    transition: transform 0.25s ease;

    &--location {
      width: 14px;
      height: 1.2rem;
      margin-top: 3px;
    }
  }

  // social
  .footer__social {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__social-title {
    font-size: $font-size-sm;            
    font-weight: $font-weight-semibold;
    text-transform: uppercase;
    letter-spacing: 0.08em;            
    color: $color-text-dark;
  }

  .footer__social-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
  }

  .footer__social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: $color-primary;
    border-radius: 50%;                 
    border: 2px solid transparent;
    transition:
      background-color 0.25s ease,
      border-color     0.25s ease,
      transform        0.2s ease,
      box-shadow       0.25s ease;

    // hover: outline del color primario + fondo blanco + sombra
    &:hover {
      background-color: $color-white;
      border-color: $color-primary;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba($color-primary, 0.25);

      .footer__social-icon,
      .footer__social-tripadvisor {
        color: $color-primary;
      }
    }
  }

  .footer__social-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: $color-white;
    transition: color 0.25s ease;
  }

  .footer__social-tripadvisor {
    width: 1.2rem;
    height: auto;
    color: $color-white;
    transition: color 0.25s ease;
    transform: scale(1.35);
    transform-origin: center;

    path {
      fill: currentColor;
      transition: fill 0.25s ease;
    }
  }

  // Badges 
  .footer__badges {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid #e8e8e8;      // † separador superior sutil
  }

  .footer__badge {
    height: 50px;
    width: 130px;
    object-fit: contain;
    transition: opacity 0.25s ease;
    &:hover { opacity: 0.8; }
    &--claims { width: 87px; }
  }

  // Men
  .footer__menu {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    letter-spacing: 0.2px;
    color: $color-text-dark;
  }

  .footer__menu-title {
    font-size: $font-size-lg;
    font-weight: $font-weight-bold;    
    letter-spacing: 0.12em;
    color: $color-primary;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  .footer__menu-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    @include sm { grid-template-columns: repeat(2, 1fr); }
  }

  .footer__menu-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer__menu-group {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__menu-heading {
    font-size: $font-size-base;
    font-weight: $font-weight-semibold;
    line-height: 1.25;
    color: $color-text-dark;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid #e8e8e8;  
  }

  .footer__menu-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-left: 0;                     
    list-style: none;
    font-size: $font-size-base;
    line-height: 1.6;
  }

  //  Links del menú con indicador animado
  .footer__menu-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: #444;                        
    padding-left: 0.875rem;
    transition: color 0.25s ease, padding-left 0.25s ease;

    // guion decorativo en reposo
    &::before {
      content: '-';
      position: absolute;
      left: 0;
      color: #ccc;
      font-weight: $font-weight-regular;
      transition: color 0.25s ease, transform 0.25s ease;
    }

    &:hover {
      color: $color-primary;
      padding-left: 1.25rem;          

      &::before {
        color: $color-primary;
        transform: translateX(2px);
      }
    }
  }

  // Bottom bar
  .footer__bottom {
    background-color: $color-primary;
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-block: $spacing-2;

    @include md {
      flex-direction: row;
      padding-block: 0;
    }
  }

  .footer__copyright {
    font-size: $font-size-sm;           
    line-height: 1.5;
    letter-spacing: 0.2px;
    color: rgba($color-white, 0.85);    
    text-align: center;
    @include md { text-align: left; }
  }

  .footer__payments {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: $spacing-1;
    padding-block: $spacing-1;

    @include md {
      align-items: flex-start;
      padding: 10px;
    }
  }

  .footer__payments-label {
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold; 
    letter-spacing: 0.05em;
    color: $color-white;
  }

  .footer__payments-img {
    height: auto;
    width: 136px;
    object-fit: contain;
  }

  .footer__whatsapp-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: linear-gradient(145deg, #31e77a 0%, #22c55e 55%, #1ea74f 100%);
    color: $color-white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 14px 30px rgba(13, 71, 30, 0.32),
      0 0 0 0 rgba(37, 211, 102, 0.45);
    z-index: 999;
    isolation: isolate;
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.3s ease, filter 0.3s ease;
    animation: whatsapp-pulse 2.4s ease-out infinite;

    &::before {
      content: '';
      position: absolute;
      inset: 3px;
      border-radius: inherit;
      border: 1px solid rgba($color-white, 0.3);
      pointer-events: none;
      z-index: 0;
    }

    &::after {
      content: '';
      position: absolute;
      top: -120%;
      left: -40%;
      width: 60%;
      height: 280%;
      background: linear-gradient(
        90deg,
        rgba($color-white, 0) 0%,
        rgba($color-white, 0.35) 50%,
        rgba($color-white, 0) 100%
      );
      transform: rotate(20deg);
      transition: left 0.45s ease;
      z-index: 0;
      pointer-events: none;
    }

    &:hover {
      transform: translateY(-3px) scale(1.06);
      box-shadow:
        0 18px 34px rgba(13, 71, 30, 0.38),
        0 0 0 10px rgba(37, 211, 102, 0.18);
      filter: saturate(1.08);
      animation-play-state: paused;

      &::after {
        left: 120%;
      }
    }

    &:focus-visible {
      outline: none;
      box-shadow:
        0 18px 34px rgba(13, 71, 30, 0.38),
        0 0 0 4px rgba($color-white, 0.95),
        0 0 0 8px rgba(#25d366, 0.38);
    }

    @include md {
      right: 1.25rem;
      bottom: 1.25rem;
    }
  }

  .footer__whatsapp-float-icon {
    width: 1.85rem;
    height: 1.85rem;
    position: relative;
    z-index: 1;
  }

  @keyframes whatsapp-pulse {
    0% {
      box-shadow:
        0 14px 30px rgba(13, 71, 30, 0.32),
        0 0 0 0 rgba(37, 211, 102, 0.38);
    }
    70% {
      box-shadow:
        0 14px 30px rgba(13, 71, 30, 0.32),
        0 0 0 12px rgba(37, 211, 102, 0);
    }
    100% {
      box-shadow:
        0 14px 30px rgba(13, 71, 30, 0.32),
        0 0 0 0 rgba(37, 211, 102, 0);
    }
  }
</style>



