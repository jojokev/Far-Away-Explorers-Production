---
import defaultImage from "../assets/default.webp";
import "glightbox/dist/css/glightbox.min.css";

const { galleryImages, imagesBanner } = Astro.props;
const previewImages = (galleryImages ?? []).map((img: any) => ({
  src: img?.src ?? defaultImage.src,
  alt: img?.alt ?? img?.alt_text ?? "Tour image",
}));
const fullImages = (imagesBanner ?? []).map((img: any) => ({
  src: img?.src ?? defaultImage.src,
  alt: img?.alt ?? img?.alt_text ?? "Tour image",
}));
const galleryItems = previewImages.map((preview: any, index: number) => ({
  preview,
  full: fullImages[index] ?? preview,
}));
const mainItem = galleryItems[0];

---

<section class="gallery-tour container">
  <div class="gallery-tour__grid">

    <!-- Main image -->
    <div class="gallery-tour__main">
      {mainItem ? (
        <a
          href={mainItem.full.src}
          class="glightbox-tour gallery-tour__link"
          data-gallery="tour-gallery"
          aria-label={`Open ${mainItem.full.alt}`}
        >
          <img src={mainItem.preview.src} alt={mainItem.preview.alt} loading="lazy" />
        </a>
      ) : (
        <img src={defaultImage.src} alt="Tour image" loading="lazy" />
      )}
    </div>

    <!-- Thumbnail grid -->
    <div class="gallery-tour__thumbs">
      {galleryItems.slice(1, 5).map((item: any) => (
        <div class="gallery-tour__thumb">
          <a
            href={item.full.src}
            class="glightbox-tour gallery-tour__link"
            data-gallery="tour-gallery"
            aria-label={`Open ${item.full.alt}`}
          >
            <img src={item.preview.src} alt={item.preview.alt} loading="lazy" />
          </a>
        </div>
      ))}

      {mainItem && (
        <a
          href={mainItem.full.src}
          id="open-tour-gallery"
          class="gallery-tour__btn"
          aria-label="View photos"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h3l1.5-2h7L17 7h3v12H4V7Zm8 9a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
          </svg>
          <span>Photos</span>
        </a>
      )}
    </div>

  </div>
</section>

<style lang="scss">
  @use '../styles/abstract/_variables' as *;
  @use '../styles/abstract/_mixins' as *;

  .gallery-tour{
    margin-top: 2rem;
  }


  // ─── Grid: 1 col mobile → 2 col (650px + 1fr) desde lg ───────────────────
  .gallery-tour__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;

    @include lg {
      grid-template-columns: 650px 1fr;
    }
  }

  // ─── Imagen principal ──────────────────────────────────────────────────────
  .gallery-tour__main {
    overflow: hidden;
    border-radius: 0.5rem;

    img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      display: block;

      @include lg {
        height: 520px;
      }
    }
  }

  // ─── Grid de miniaturas ────────────────────────────────────────────────────
  .gallery-tour__thumbs {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;

    @include sm {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    @include lg {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  // ─── Cada miniatura ────────────────────────────────────────────────────────
  .gallery-tour__thumb {
    overflow: hidden;
    border-radius: 0.5rem;

    img {
      width: 100%;
      height: 72px;
      object-fit: cover;
      display: block;

      @include sm {
        height: 250px;
      }
    }
  }

  // ─── Link wrapper (glightbox) ──────────────────────────────────────────────
  .gallery-tour__link {
    display: block;
  }

  // ─── Botón "Ver fotos" ─────────────────────────────────────────────────────
  .gallery-tour__btn {
    position: static;
    justify-self: end;
    grid-column: 1 / -1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: $color-primary;
    color: $color-white;
    padding: $spacing-2 $spacing-4;
    font-size: $font-size-base;
    font-weight: $font-weight-medium;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: $transition-fast;

    svg {
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
    }

    &:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    @include sm {
      position: absolute;
      bottom: 1rem;
      right: 1rem;
      grid-column: auto;
    }
  }
</style>

<script>
  import GLightbox from "glightbox";

  const lightbox = GLightbox({
    selector: ".glightbox-tour",
    touchNavigation: true,
    loop: true,
  });

  const openButton = document.getElementById("open-tour-gallery");
  openButton?.addEventListener("click", (event) => {
    event.preventDefault();
    lightbox.openAt(0);
  });
</script>
