---
import { Icon } from "astro-icon/components";
import logo from "../assets/logo-far-away-2.webp";

const navLinks = [
  { label: "Inicio",    href: "/", icon: "ion:home-outline" },
  { label: "Destinos",  href: "#", icon: "ion:earth-outline",
    submenu: [
      { label: "Cusco",   href: "/cusco", icon: "ion:flag-outline" },
      { label: "Arequipa", href: "/arequipa", icon: "ion:flag-outline" },
      { label: "Lima",    href: "/lima", icon: "ion:flag-outline" },
      { label: "Nazca", href: "/nazca", icon: "ion:flag-outline" },
      { label: "Puno", href: "/puno", icon: "ion:flag-outline" },
      { label: "Bolivia", href: "/bolivia", icon: "ion:flag-outline" },
      { label: "Ica",     href: "/ica", icon: "ion:flag-outline" },
      { label: "Nazca", href: "/nazca", icon: "ion:flag-outline" },
    ]
  },
  { label: "Paquetes",  href: "/paquetes", icon: "ion:briefcase-outline" },
  { label: "Full Day",  href: "#", icon: "ion:sunny-outline" },
  { label: "Trekking",  href: "#", icon: "ion:footsteps-outline" },
];

const { background = "light" } = Astro.props;
const backgroundMode = background === "white" ? "dark" : background;
---

<header class="header">

  <!-- ── Top bar ─────────────────────────────────── -->
  <div class="header__topbar">
    <div class="container">
      <div class="header__topbar-inner">
        <a href="/">
          <img src={logo.src} alt="Logo Far Away" class="header__logo header__logo--desktop" />
        </a>
        <div class="header__actions">
          <div class="header__links">
            <a href="https://www.facebook.com/share/1DVDJHeDRC/" target="_blank" class="header__social" aria-label="Facebook">
              <Icon name="ion:logo-facebook" class="header__social-icon" />
            </a>
            <a href="#" class="header__social" aria-label="Instagram">
              <Icon name="ion:logo-instagram" class="header__social-icon" />
            </a>
            <a href="#" class="header__social" aria-label="TikTok">
              <Icon name="ion:logo-tiktok" class="header__social-icon" />
            </a>
            <a href="https://www.tripadvisor.com.pe/Attraction_Review-g294314-d34235732-Reviews-Far_Away_Explorers-Cusco_Cusco_Region.html" target="_blank" class="header__social" aria-label="TripAdvisor">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 36" fill="none" class="header__social-tripadvisor" aria-hidden="true">
                <path d="M32.4566 14.4819L34.8261 12.1187H29.5715C26.941 10.4715 23.7641 9.51221 20.3283 9.51221C16.8969 9.51221 13.7289 10.4736 11.1027 12.1187H5.83496L8.20445 14.4819C6.75207 15.6966 5.84157 17.4463 5.84157 19.3891C5.84157 23.0555 9.08429 26.028 13.0839 26.028C14.9839 26.028 16.7149 25.3563 18.0072 24.2582L20.3284 26.575L22.6496 24.2602C23.9419 25.3583 25.6707 26.028 27.5706 26.028C31.5702 26.028 34.8173 23.0555 34.8173 19.3891C34.8195 17.4443 33.909 15.6946 32.4566 14.4819ZM13.086 23.8821C10.3787 23.8821 8.18475 21.871 8.18475 19.3891C8.18475 16.9073 10.3787 14.8961 13.086 14.8961C15.7934 14.8961 17.9873 16.9073 17.9873 19.3891C17.9873 21.871 15.7934 23.8821 13.086 23.8821ZM20.3305 19.2584C20.3305 16.3019 17.9852 13.7639 14.8895 12.6798C16.5635 12.0382 18.3998 11.6823 20.3283 11.6823C22.2568 11.6823 24.0953 12.0382 25.7694 12.6798C22.6759 13.7659 20.3305 16.302 20.3305 19.2584ZM27.5728 23.8821C24.8655 23.8821 22.6715 21.871 22.6715 19.3891C22.6715 16.9073 24.8655 14.8961 27.5728 14.8961C30.2802 14.8961 32.4741 16.9073 32.4741 19.3891C32.4741 21.871 30.2802 23.8821 27.5728 23.8821ZM27.5728 17.032C26.1533 17.032 25.0037 18.0859 25.0037 19.3871C25.0037 20.6883 26.1533 21.7422 27.5728 21.7422C28.9923 21.7422 30.142 20.6883 30.142 19.3871C30.1419 18.0879 28.9923 17.032 27.5728 17.032ZM15.6552 19.3891C15.6552 20.6903 14.5055 21.7442 13.086 21.7442C11.6666 21.7442 10.5169 20.6903 10.5169 19.3891C10.5169 18.0879 11.6666 17.034 13.086 17.034C14.5055 17.032 15.6552 18.0879 15.6552 19.3891Z" fill="currentColor"></path>
              </svg>
            </a>
            <span class="header__links-divider" aria-hidden="true"></span>
            <a href="https://www.tripadvisor.com.pe/Attraction_Review-g294314-d34235732-Reviews-Far_Away_Explorers-Cusco_Cusco_Region.html" target="_blank" class="header__link">Reviews</a>
            <a href="#" class="header__link">Blogs</a>
            <a href="/about-us" class="header__link">Nosotros</a>
            <a href="/terminos-y-condiciones" class="header__link header__link--hidden-xs">Terminos y condiciones</a>
          </div>
          <div class="header__contact">
            <a href="tel:+51900086730" class="header__contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 19 19" fill="none">
                <path d="M3 1H7L9 6L6.5 7.5C7.57096 9.67153 9.32847 11.429 11.5 12.5L13 10L18 12V16C18 16.5304 17.7893 17.0391 17.4142 17.4142C17.0391 17.7893 16.5304 18 16 18C12.0993 17.763 8.42015 16.1065 5.65683 13.3432C2.8935 10.5798 1.23705 6.90074 1 3C1 2.46957 1.21071 1.96086 1.58579 1.58579C1.96086 1.21071 2.46957 1 3 1Z" stroke="#AA5C00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              +51 900 086 730
            </a>
            <a href="mailto:info@farawayexplorers.com" class="header__contact-item header__contact-item--hidden-xs">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M3 7C3 6.46957 3.21071 5.96086 3.58579 5.58579C3.96086 5.21071 4.46957 5 5 5H19C19.5304 5 20.0391 5.21071 20.4142 5.58579C20.7893 5.96086 21 6.46957 21 7M3 7V17C3 17.5304 3.21071 18.0391 3.58579 18.4142C3.96086 18.7893 4.46957 19 5 19H19C19.5304 19 20.0391 18.7893 20.4142 18.4142C20.7893 18.0391 21 17.5304 21 17V7M3 7L12 13L21 7" stroke="#AA5C00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              info@farawayexplorers.com
            </a>
            <a href="/contacto" class="header__contact-cta">
              Contactanos
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="14" viewBox="0 0 16 14" fill="none">
                <path d="M1 7H15M15 7L9 13M15 7L9 1" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Nav bar ─────────────────────────────────── -->
  <nav class={`header__nav header__nav--${backgroundMode}`} aria-label="Navegación principal">
    <div class="container">
      <div class="header__nav-inner">

        <a href="/" class="header__nav-logo-link">
          <img src={logo.src} alt="Far Away Expeditions" class="header__logo header__logo--mobile" />
        </a>

        <ul class="header__nav-list" role="list">
          {navLinks.map((item) => (
            <li class={`header__nav-item ${item.submenu ? "header__nav-item--has-submenu" : ""}`}>
              <a
                href={item.href}
                class="header__nav-link"
                aria-haspopup={item.submenu ? "true" : undefined}
              >
                <Icon name={item.icon} class="header__nav-link-icon" aria-hidden="true" />
                <span>{item.label}</span>
                {item.submenu && (
                  <Icon name="ion:chevron-down" class="header__nav-link-chevron" aria-hidden="true" />
                )}
              </a>

              {item.submenu && (
                <ul class="header__submenu" role="list">
                  {item.submenu.map((sub) => (
                    <li>
                      <a href={sub.href} class="header__submenu-link">
                        <Icon name={sub.icon} class="header__submenu-icon" aria-hidden="true" />
                        <span>{sub.label}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>

        <button
          type="button"
          class="header__hamburger"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="header__hamburger-bar"></span>
          <span class="header__hamburger-bar"></span>
          <span class="header__hamburger-bar"></span>
        </button>

      </div>
    </div>
  </nav>

  <!-- ── Mobile menu ─────────────────────────────── -->
  <div id="mobile-menu" class={`header__mobile-menu header__mobile-menu--${backgroundMode}`} aria-hidden="true">
    <ul class="header__mobile-list" role="list">
      {navLinks.map((item) => (
        <li class="header__mobile-item">
          {item.submenu ? (
            <>
              <button type="button" class="header__mobile-link header__mobile-link--toggle" aria-expanded="false">
                <span class="header__mobile-link-left">
                  <Icon name={item.icon} class="header__mobile-icon" aria-hidden="true" />
                  <span>{item.label}</span>
                </span>
                <Icon name="ion:chevron-down" class="header__mobile-chevron" aria-hidden="true" />
              </button>
              <ul class="header__mobile-submenu" role="list">
                {item.submenu.map((sub) => (
                  <li>
                    <a href={sub.href} class="header__mobile-sublink">
                      <Icon name={sub.icon} class="header__mobile-icon header__mobile-icon--sm" aria-hidden="true" />
                      <span>{sub.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={item.href} class="header__mobile-link">
              <span class="header__mobile-link-left">
                <Icon name={item.icon} class="header__mobile-icon" aria-hidden="true" />
                <span>{item.label}</span>
              </span>
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>

</header>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins' as *;

  // ─── Variables locales ──────────────────────────────────────────────────────
  $nav-height:            80px;
  $mobile-menu-speed:     0.32s;
  $submenu-speed:         0.25s;
  $nav-link-color-rest:   rgba($color-white, 0.95);
  $submenu-bg:            #1a1208;       // ← más oscuro que el nav para contraste
  $submenu-shadow:        0 12px 32px rgba(0, 0, 0, 0.35);

  // ─── Top bar ────────────────────────────────────────────────────────────────
  .header__topbar {
    width: 100%;
    border-bottom: 1px solid #f0e8df;
  }

  .header__topbar-inner {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-block: $spacing-2;
    @include md { justify-content: space-between; }
  }

  // ─── Logo ───────────────────────────────────────────────────────────────────
  .header__logo {
    height: 3.5rem;
    width: auto;
    transition: opacity 0.25s ease;
    &:hover { opacity: 0.85; }

    &--desktop { display: none; @include md { display: block; } }
    &--mobile  { display: block; height: 2.75rem; @include md { display: none; } }
  }

  // ─── Actions ────────────────────────────────────────────────────────────────
  .header__actions {
    display: flex;
    flex-direction: column;
    gap: $spacing-2;
    width: 100%;
    @include md { width: auto; gap: 0.375rem; }
  }

  .header__links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.125rem;
    justify-content: center;
    @include md { justify-content: flex-end; }
  }

  .header__links-divider {
    display: inline-block;
    width: 1px;
    height: 1rem;
    background-color: #ddd;
    margin-inline: 0.25rem;
  }

  .header__link {
    position: relative;
    font-weight: $font-weight-medium;
    font-size: $font-size-sm;
    padding: $spacing-1 $spacing-2;
    color: #444;
    transition: color 0.25s ease;

    &::after {
      content: '';
      position: absolute;
      bottom: 0; left: 50%;
      transform: translateX(-50%) scaleX(0);
      width: 70%; height: 1.5px;
      background-color: $color-primary;
      border-radius: 2px;
      transition: transform 0.25s ease;
    }

    &:hover { color: $color-primary; &::after { transform: translateX(-50%) scaleX(1); } }
    &--hidden-xs { display: none; @include sm { display: inline; } }
  }

  .header__social {
    display: inline-flex;
    align-items: center;
    padding: $spacing-2 0.375rem;
    color: $color-text-muted;
    transition: color 0.25s ease, transform 0.2s ease;
    &:hover { color: $color-primary; transform: translateY(-1px); }
  }

  .header__social-icon { font-size: 1.15rem; display: block; }

  .header__social-tripadvisor {
    width: 2rem;
    height: auto;
    display: block;
    transform: scale(1.2);
    transform-origin: center;
  }

  .header__contact {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: $spacing-2;
    @include md { justify-content: flex-end; }
  }

  .header__contact-item {
    display: inline-flex;
    align-items: center;
    gap: $spacing-1;
    padding: $spacing-1 $spacing-2;
    font-size: $font-size-sm;
    font-weight: $font-weight-medium;
    color: #444;
    border-radius: 4px;
    transition: color 0.25s ease, background-color 0.25s ease;

    svg path { transition: stroke 0.25s ease; }
    &:hover { color: $color-primary; background-color: rgba($color-primary, 0.06); svg path { stroke: $color-primary; } }
    @include md { font-size: $font-size-base; }
    &--hidden-xs { display: none; @include sm { display: inline-flex; } }
  }

  .header__contact-cta {
    display: inline-flex;
    align-items: center;
    gap: $spacing-1;
    background-color: $color-primary;
    color: $color-white;
    padding: $spacing-2 $spacing-4;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    letter-spacing: 0.02em;
    border-radius: 4px;
    border: 2px solid $color-primary;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;

    svg path { transition: stroke 0.25s ease; }
    &:hover { background-color: $color-white; color: $color-primary; transform: translateY(-2px); box-shadow: 0 4px 14px rgba($color-primary, 0.22); svg path { stroke: $color-primary; } }
    @include md { font-size: $font-size-base; }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // NAV — 80px fijo
  // ═══════════════════════════════════════════════════════════════════════════
  .header__nav {
    backdrop-filter: blur(3px);
    height: 80px;
    position: relative;
    z-index: 100;
    display: flex;

    .container { width: 100%; }

    &--light { background-color: rgba(0, 0, 0, 0.2); }
    &--dark  { background-color: rgba($color-white, 0.98); }
  }


  .header__nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    @include md { justify-content: center; }
  }

  .header__nav-logo-link {
    display: flex;
    align-items: center;
    @include md { display: none; }
  }

  // ─── Lista principal ────────────────────────────────────────────────────────
  .header__nav-list {
    display: none;
    list-style: none;

    @include md {
      display: flex;
      align-items: center;
      height: 100%;
      gap: 0;
    }
  }

  // ─── Item con submenu ───────────────────────────────────────────────────────
  .header__nav-item {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;

    // ← abre el submenu al hover
    &--has-submenu:hover {
      .header__submenu {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
        visibility: visible;
      }
      .header__nav-link-chevron {
        transform: rotate(180deg);
      }
    }
  }

  // ─── Nav link ───────────────────────────────────────────────────────────────
  .header__nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    height: $nav-height;
    padding-inline: 1.1rem;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: $nav-link-color-rest;
    white-space: nowrap;
    transition: color 0.25s ease, background-color 0.25s ease;

    &::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 2px;
      background-color: $color-primary;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }

    &:hover, .header__nav-item--has-submenu:hover & {
      background-color: rgba($color-white, 0.05);
      &::after { transform: scaleX(1); }
    }

    &.active { color: $color-white; &::after { transform: scaleX(1); } }
  }

  .header__nav-link-icon {
    font-size: 1rem;
    flex-shrink: 0;
    opacity: 0.75;
    transition: opacity 0.25s ease;

    .header__nav-link:hover & { opacity: 1; }
  }

  .header__nav-link-chevron {
    font-size: 0.75rem;
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform $submenu-speed ease, opacity 0.25s ease;

    .header__nav-link:hover & { opacity: 1; }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // SUBMENU DROPDOWN
  // ═══════════════════════════════════════════════════════════════════════════
  .header__submenu {
    position: absolute;
    top: calc(#{$nav-height} - 2px);
    left: 30%;                                    // ← era 0%
    transform: translateX(-50%) translateY(-8px);
    min-width: 250px;
    list-style: none;
    background-color: $submenu-bg;
    border: 1px solid rgba($color-primary, 0.3);
    border-top: 2px solid $color-primary; // ← acento de marca en el borde superior
    border-radius: 0 0 8px 8px;
    box-shadow: $submenu-shadow;
    padding: 0.375rem 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity    $submenu-speed ease,
      transform  $submenu-speed ease,
      visibility $submenu-speed ease;
    z-index: 200;

    // ← triángulo decorativo apuntando al nav
    &::before {
      content: '';
      position: absolute;
      top: -7px;
      left: 50%;
      transform: translateX(-50%);
      width: 12px; height: 12px;
      background-color: $color-primary;
      clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    }
  }

  .header__submenu-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1.125rem;
    font-size: $font-size-sm;
    font-weight: $font-weight-medium;
    color: rgba($color-white, 0.9);
    letter-spacing: 0.03em;
    white-space: nowrap;
    border-left: 2px solid transparent;
    transition:
      color            0.2s ease,
      background-color 0.2s ease,
      border-color     0.2s ease,
      padding-left     0.2s ease;

    &:hover {
      color: $color-white;
      background-color: rgba($color-primary, 0.12);
      border-left-color: $color-primary;
      padding-left: 1.375rem;           // ← leve indent al hover
    }
  }

  .header__submenu-icon {
    font-size: 1rem;
    flex-shrink: 0;
    color: $color-primary;
    opacity: 0.8;
    transition: opacity 0.2s ease, transform 0.2s ease;

    .header__submenu-link:hover & { opacity: 1; transform: scale(1.1); }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // HAMBURGER
  // ═══════════════════════════════════════════════════════════════════════════
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem; height: 2.5rem;
    padding: 0.375rem;
    background: transparent;
    border: 1.5px solid rgba($color-white, 0.2);
    border-radius: 6px;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.25s ease, background-color 0.25s ease;

    &:hover { border-color: rgba($color-primary, 0.6); background-color: rgba($color-primary, 0.08); }
    @include md { display: none; }

    &[aria-expanded="true"] {
      border-color: $color-primary;
      background-color: rgba($color-primary, 0.12);
      .header__hamburger-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .header__hamburger-bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
      .header__hamburger-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    }
  }

  .header__hamburger-bar {
    display: block;
    width: 100%; height: 2px;
    background-color: $color-white;
    border-radius: 2px;
    transform-origin: center;
    transition: transform $mobile-menu-speed ease, opacity $mobile-menu-speed ease, background-color 0.25s ease;
    .header__hamburger:hover & { background-color: $color-primary; }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MOBILE MENU
  // ═══════════════════════════════════════════════════════════════════════════
  .header__mobile-menu {
    background-color: $color-nav-bg;
    border-bottom: 2px solid rgba($color-primary, 0.6);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transition: max-height $mobile-menu-speed ease, opacity $mobile-menu-speed ease;
    position: relative;
    z-index: 5;

    &.is-open { max-height: 600px; opacity: 1; pointer-events: auto; }
    @include md { display: none !important; }
  }

  .header__mobile-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0;
  }

  .header__mobile-item { display: flex; flex-direction: column; }

  // ─── Link mobile base ───────────────────────────────────────────────────────
  .header__mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.5rem;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: $nav-link-color-rest;
    border: none;
    background: transparent;
    width: 100%;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;

    &:hover, &[aria-expanded="true"] {
      color: $color-white;
      background-color: rgba($color-white, 0.05);
      border-left-color: $color-primary;
    }

    &.active { color: $color-white; border-left-color: $color-primary; }
  }

  .header__mobile-link-left {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .header__mobile-icon {
    font-size: 1.1rem;
    color: $color-primary;
    flex-shrink: 0;

    &--sm { font-size: 0.95rem; }
  }

  .header__mobile-chevron {
    font-size: 0.875rem;
    color: rgba($color-white, 0.5);
    transition: transform $submenu-speed ease;
    flex-shrink: 0;

    .header__mobile-link[aria-expanded="true"] & {
      transform: rotate(180deg);
    }
  }

  // ─── Submenu mobile (acordeón) ───────────────────────────────────────────────
  .header__mobile-submenu {
    list-style: none;
    max-height: 0;
    overflow: hidden;
    background-color: rgba($color-white, 0.03);
    border-left: 2px solid rgba($color-primary, 0.4);
    margin-left: 1.5rem;
    transition: max-height $submenu-speed ease;

    &.is-open { max-height: 300px; }
  }

  .header__mobile-sublink {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1.25rem;
    font-size: $font-size-sm;
    font-weight: $font-weight-medium;
    color: rgba($color-white, 0.65);
    letter-spacing: 0.03em;
    transition: color 0.2s ease, background-color 0.2s ease, padding-left 0.2s ease;

    &:hover {
      color: $color-white;
      background-color: rgba($color-primary, 0.1);
      padding-left: 1.5rem;
    }
  }

  .header__nav--dark {
    .header__nav-link {
      color: $color-primary;

      &:hover,
      .header__nav-item--has-submenu:hover & {
        color: #121212;
        background-color: rgba(#000, 0.06);
      }

      &.active {
        color: #121212;
      }
    }

    .header__nav-link-icon,
    .header__nav-link-chevron {
      opacity: 0.9;
    }

    .header__hamburger {
      border-color: rgba(#000, 0.35);

      &:hover {
        border-color: rgba($color-primary, 0.6);
      }
    }

    .header__hamburger-bar {
      background-color: #121212;
    }

    .header__submenu {
      background-color: $color-white;
      border: 1px solid rgba($color-primary, 0.22);
      border-top: 2px solid $color-primary;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
    }

    .header__submenu-link {
      color: #1f1f1f;

      &:hover {
        color: #111111;
        background-color: rgba($color-primary, 0.14);
      }
    }
  }

  .header__mobile-menu--dark {
    background-color: $color-white;
    border-bottom: 2px solid rgba($color-primary, 0.35);

    .header__mobile-link {
      color: #1a1a1a;

      &:hover,
      &[aria-expanded="true"] {
        color: #121212;
        background-color: rgba(#000, 0.06);
      }

      &.active {
        color: #121212;
      }
    }

    .header__mobile-chevron {
      color: rgba(#1f1f1f, 0.75);
    }

    .header__mobile-submenu {
      background-color: rgba(#000, 0.04);
    }

    .header__mobile-sublink {
      color: #2a2a2a;

      &:hover {
        color: #111111;
      }
    }
  }
</style>

<script>

  // ─── Hamburger ──────────────────────────────────────────────────────────────
  const hamburger  = document.querySelector(".header__hamburger") as HTMLButtonElement;
  const mobileMenu = document.querySelector(".header__mobile-menu") as HTMLElement;

  const closeMobileMenu = () => {
    mobileMenu?.classList.remove("is-open");
    hamburger?.setAttribute("aria-expanded", "false");
    hamburger?.setAttribute("aria-label", "Abrir menú");
    mobileMenu?.setAttribute("aria-hidden", "true");
  };

  hamburger?.addEventListener("click", () => {
    const isOpen = mobileMenu.classList.toggle("is-open");
    hamburger.setAttribute("aria-expanded", String(isOpen));
    hamburger.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
    mobileMenu.setAttribute("aria-hidden", String(!isOpen));
  });

  document.addEventListener("click", (e) => {
    const header = document.querySelector(".header") as HTMLElement;
    if (!header?.contains(e.target as Node)) closeMobileMenu();
  });

  // ─── Submenús mobile (acordeón) ─────────────────────────────────────────────
  document.querySelectorAll(".header__mobile-link--toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const submenu = btn.nextElementSibling as HTMLElement;
      const isOpen  = submenu?.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", String(isOpen));
    });
  });

  // ─── Cierra al hacer click en un link del mobile menu ───────────────────────
  mobileMenu?.querySelectorAll(".header__mobile-sublink, .header__mobile-link:not(.header__mobile-link--toggle)").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });
</script>
