---
import defaultImage from "../assets/default.webp";
import { Icon } from "astro-icon/components";

const blogs = [
  {
    title: "4-day Inca Trail Tour Frequently Asked Questions",
    date: "16 FEB 2026",
    category: "Trekking",
    readTime: "5 min",
    description: "Descubre cómo disfrutar de la libertad de viajar sin compañía con estos prácticos consejos para tu próxima aventura.",
    image: defaultImage.src,
  },
  {
    title: "Qeshuachaca Tourism",
    date: "16 FEB 2026",
    category: "Cultura",
    readTime: "3 min",
    description: "Explora el único puente inca de cuerda que sigue en pie, una tradición viva que conecta el pasado con el presente.",
    image: defaultImage.src,
  },
  {
    title: "Your Checklist for How to Train for Machu Picchu Hiking Tours",
    date: "16 FEB 2026",
    category: "Consejos",
    readTime: "7 min",
    description: "Todo lo que necesitas saber para prepararte físicamente y disfrutar al máximo tu caminata a Machu Picchu.",
    image: defaultImage.src,
  },
];
---

<section class="blogs">
  <div class="container">
    <div class="blogs__inner">

      <!-- ── Header ───────────────────────────────── -->
      <div class="blogs__header">
        <div class="blogs__header-text">
          <p class="blogs__eyebrow">OUR BLOGS</p>
          <h2 class="blogs__title">Travel Tips and Advice</h2>
          <p class="blogs__lead">
            Inspírate con nuestras guías y consejos para vivir Peru al máximo.
          </p>
        </div>
        <a href="#" class="blogs__header-cta">
          Ver todos los artículos
          <Icon name="ion:arrow-forward" class="blogs__header-cta-icon" aria-hidden="true" />
        </a>
      </div>

      <!-- ── Grid ─────────────────────────────────── -->
      <div class="blogs__grid">
        {blogs.map((blog, index) => (
          <article class={`blogs__card ${index === 0 ? "blogs__card--featured" : ""}`}>

            <a href="#" class="blogs__card-img-link" tabindex="-1" aria-hidden="true">
              <img
                src={blog.image}
                alt={blog.title}
                class="blogs__card-img"
                loading="lazy"
              />
              <!-- ← overlay con categoría sobre la imagen -->
              <span class="blogs__card-category">{blog.category}</span>
            </a>

            <div class="blogs__card-body">

              <!-- Meta: fecha + tiempo de lectura -->
              <div class="blogs__card-meta">
                <span class="blogs__card-date">
                  <Icon name="ion:calendar-outline" class="blogs__card-meta-icon" aria-hidden="true" />
                  {blog.date}
                </span>
                <span class="blogs__card-read-time">
                  <Icon name="ion:time-outline" class="blogs__card-meta-icon" aria-hidden="true" />
                  {blog.readTime} lectura
                </span>
              </div>

              <h3 class="blogs__card-title">
                <a href="#" class="blogs__card-title-link">{blog.title}</a>
              </h3>

              <p class="blogs__card-desc">{blog.description}</p>

              <!-- ← CTA explícito dentro de la card -->
              <a href="#" class="blogs__card-cta">
                Leer artículo
                <Icon name="ion:arrow-forward" class="blogs__card-cta-icon" aria-hidden="true" />
              </a>

            </div>

          </article>
        ))}
      </div>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins'   as *;

  // ─── Variables locales ──────────────────────────────────────────────────────
  $blogs-color-text:      #151515;
  $blogs-img-height:      220px;        // ← única altura para todas las cards
  $blogs-shadow-card:     0 2px 12px rgba(0, 0, 0, 0.06);
  $blogs-shadow-hover:    0 12px 32px rgba(0, 0, 0, 0.12);
  
  // ─── Section ────────────────────────────────────────────────────────────────
  .blogs {
    padding-block: 2.5rem;
    @include md { padding-block: 2.5rem; }
  }

  // ─── Inner ──────────────────────────────────────────────────────────────────
  .blogs__inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    width: 100%;
  }

  // ─── Header ─────────────────────────────────────────────────────────────────
  // ← header en fila: texto a la izquierda, CTA a la derecha
  .blogs__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    width: 100%;

    @include md {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .blogs__header-text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .blogs__eyebrow {
    font-size: $font-size-sm;
    font-weight: $font-weight-bold;
    letter-spacing: 0.14em;
    color: $color-primary;
    display: flex;
    align-items: center;
    gap: 0.5rem;

    &::before,
    &::after {
      content: '';
      display: inline-block;
      width: 2rem;
      height: 2px;
      background-color: $color-primary;
      border-radius: 2px;
    }
  }

  .blogs__title {
    font-size: 1.875rem;
    font-weight: $font-weight-bold;
    line-height: 1.2;
    color: $color-text-dark;
    @include md { font-size: 2rem; }
  }

  .blogs__lead {
    font-size: $font-size-base;
    color: rgba($blogs-color-text, 0.6);
    line-height: 1.5;
  }

  // ← CTA del header (outline en lugar de filled para no competir con los de las cards)
  .blogs__header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    color: $color-primary;
    border: 1.5px solid $color-primary;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    transition:
      background-color 0.25s ease,
      color            0.25s ease,
      transform        0.2s ease,
      box-shadow       0.2s ease;

    &:hover {
      background-color: $color-primary;
      color: $color-white;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba($color-primary, 0.22);
    }
  }

  .blogs__header-cta-icon {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform 0.2s ease;

    .blogs__header-cta:hover & { transform: translateX(3px); }
  }

  // ─── Grid ───────────────────────────────────────────────────────────────────
  .blogs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    width: 100%;

    @include md { grid-template-columns: repeat(2, 1fr); }
    @include lg { grid-template-columns: repeat(3, 1fr); }
  }

  // ─── Card base ──────────────────────────────────────────────────────────────
  .blogs__card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    overflow: hidden;
    background-color: $color-white;
    box-shadow: $blogs-shadow-card;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition:
      box-shadow   0.3s ease,
      transform    0.3s ease,
      border-color 0.3s ease;

    &:hover {
      box-shadow: $blogs-shadow-hover;
      transform: translateY(-4px);
      border-color: rgba($color-primary, 0.18);
    }

    // ← primera card destacada ocupa 2 columnas en lg
    &--featured {
      @include lg { grid-column: span 1; }  // mantiene 1 col — ajusta a span 2 si prefieres

    }
  }

  // ─── Imagen ─────────────────────────────────────────────────────────────────
  .blogs__card-img-link {
    position: relative;
    display: block;
    overflow: hidden;
    flex-shrink: 0;
    height: $blogs-img-height;          // ← altura fija en el link, no en la img
  }

  .blogs__card-img {
    height: 100%;                       // ← hereda del link
    width: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
    will-change: transform;
    display: block;

    .blogs__card:hover & { transform: scale(1.05); }
  }

  // ─── Card featured — solo quita la sobreescritura de altura ─────────────────
  .blogs__card {
    &--featured {
      @include lg { grid-column: span 1; }
      // ← elimina el bloque .blogs__card-img { height: $blogs-img-height-feat; }
    }
  }

  // ─── Badge de categoría sobre la imagen ─────────────────────────────────────
  .blogs__card-category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background-color: $color-primary;
    color: $color-white;
    font-size: 0.7rem;
    font-weight: $font-weight-bold;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.625rem;
    border-radius: 99px;               // ← píldora
  }

  // ─── Body ───────────────────────────────────────────────────────────────────
  .blogs__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.25rem 1.25rem 1.5rem;
    flex: 1;
  }

  // ─── Meta (fecha + tiempo lectura) ───────────────────────────────────────────
  .blogs__card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .blogs__card-date,
  .blogs__card-read-time {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: rgba($blogs-color-text, 0.55);
    letter-spacing: 0.02em;
  }

  .blogs__card-date { color: $color-primary; font-weight: $font-weight-semibold; }

  .blogs__card-meta-icon {
    width: 0.8rem;
    height: 0.8rem;
    flex-shrink: 0;
  }

  // ─── Título ─────────────────────────────────────────────────────────────────
  .blogs__card-title {
    font-size: 1rem;
    font-weight: $font-weight-semibold;
    line-height: 1.4;
    color: $blogs-color-text;
    margin: 0;
    // ← clamp a 2 líneas: evita que títulos largos rompan el layout
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blogs__card-title-link {
    color: inherit;
    transition: color 0.25s ease;

    &:hover { color: $color-primary; }

    &:focus-visible {
      outline: 2px solid rgba($color-primary, 0.6);
      outline-offset: 2px;
      border-radius: 2px;
    }
  }

  // ─── Descripción ────────────────────────────────────────────────────────────
  .blogs__card-desc {
    font-size: $font-size-sm;
    line-height: 1.65;
    color: rgba($blogs-color-text, 0.65);
    // ← clamp a 2 líneas para alinear los CTA en el grid
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  // ─── CTA de la card ─────────────────────────────────────────────────────────
  .blogs__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.375rem;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    color: $color-primary;
    border-bottom: 1.5px solid transparent;
    padding-bottom: 1px;
    width: fit-content;
    transition:
      border-color 0.25s ease,
      gap          0.25s ease;

    // ← subrayado que aparece al hover
    &:hover {
      border-bottom-color: $color-primary;
      gap: 0.5rem;                     // ← la flecha se aleja del texto
    }
  }

  .blogs__card-cta-icon {
    width: 0.8rem;
    height: 0.8rem;
    transition: transform 0.25s ease;

    .blogs__card-cta:hover & { transform: translateX(2px); }
  }
</style>
