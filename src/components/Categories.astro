---
import imgArequipa from "../assets/cards/card-arequipa.webp";
import imgLima from "../assets/cards/card-lima.webp";
import imgIca from "../assets/cards/card-ica.webp";
import imgCusco from "../assets/cards/card-cusco.webp";

const destinations = {
  arequipa: { title: "Arequipa", image: imgArequipa.src, link: "/arequipa" },
  lima:     { title: "Lima",     image: imgLima.src, link: "/lima" },
  ica:      { title: "Ica",      image: imgIca.src, link: "/ica" },
  cusco:    { title: "Cusco",    image: imgCusco.src, link: "/cusco" },
};
---

<section class="destinations">
  <div class="container">

    <!-- ── Header ───────────────────────────────────── -->
    <div class="destinations__header">
      <div class="destinations__titles">
        <p class="destinations__eyebrow">EXPLORE</p>
        <h2 class="destinations__title">Our destinations</h2>
      </div>
      <p class="destinations__subtitle">
        Explore the wonders of our popular destinations
      </p>
    </div>

    <!-- ── Grid ─────────────────────────────────────── -->
    <div class="destinations__grid">

      <!-- Tarjeta principal (Arequipa) -->
      <a
        href={destinations.arequipa.link}
        class="destinations__card destinations__card--featured"
        aria-label={destinations.arequipa.title}
      >
        <img
          src={destinations.arequipa.image}
          alt={destinations.arequipa.title}
          class="destinations__card-img"
          loading="lazy"
        />
        <div class="destinations__card-overlay" aria-hidden="true"></div>
        <h3 class="destinations__card-label">{destinations.arequipa.title}</h3>
      </a>

      <!-- Sub-grid (Lima, Ica, Cusco) -->
      <div class="destinations__subgrid">

        <a href={destinations.lima.link} class="destinations__card" aria-label={destinations.lima.title}>
          <img src={destinations.lima.image} alt={destinations.lima.title} class="destinations__card-img" loading="lazy" />
          <div class="destinations__card-overlay" aria-hidden="true"></div>
          <h3 class="destinations__card-label destinations__card-label--sm">{destinations.lima.title}</h3>
        </a>

        <a href={destinations.ica.link} class="destinations__card" aria-label={destinations.ica.title}>
          <img src={destinations.ica.image} alt={destinations.ica.title} class="destinations__card-img" loading="lazy" />
          <div class="destinations__card-overlay" aria-hidden="true"></div>
          <h3 class="destinations__card-label destinations__card-label--sm">{destinations.ica.title}</h3>
        </a>

        <a href={destinations.cusco.link} class="destinations__card destinations__card--wide" aria-label={destinations.cusco.title}>
          <img src={destinations.cusco.image} alt={destinations.cusco.title} class="destinations__card-img" loading="lazy" />
          <div class="destinations__card-overlay" aria-hidden="true"></div>
          <h3 class="destinations__card-label destinations__card-label--sm">{destinations.cusco.title}</h3>
        </a>

      </div>
    </div>

  </div>
</section>

<style lang="scss">
  @use '../styles/abstract/variables' as *;
  @use '../styles/abstract/mixins'   as *;

  // ─── Variables locales ──────────────────────────────────────────────────────
  $dest-radius:          1.25rem;   // rounded-2xl
  $dest-overlay-from:    rgba(0, 0, 0, 0.72);
  $dest-overlay-via:     rgba(0, 0, 0, 0.20);

  // Alturas por breakpoint
  $dest-h-featured-mobile: 340px;
  $dest-h-featured-sm:     420px;
  $dest-h-featured-md:     600px;
  $dest-h-card-mobile:     260px;
  $dest-h-card-sm:         292px;

  // ─── Section ────────────────────────────────────────────────────────────────
  .destinations {
    padding-block: 2.5rem;
    @include md { padding-block: 2.5rem; }
  }

  // ─── Header ─────────────────────────────────────────────────────────────────
  .destinations__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  text-align: center;
  width: 100%;
  }

  .destinations__titles {
  display: flex;
  flex-direction: column;
  align-items: center;      // ← era flex-start
  gap: 0.375rem;
  width: 100%;
  text-align: center;       // ← era left
  }

  .destinations__eyebrow {
  font-size: $font-size-sm;
  font-weight: $font-weight-bold;
  letter-spacing: 0.14em;
  color: $color-primary;
  display: flex;
  align-items: center;
  justify-content: center;  // ← añadido
  gap: 0.5rem;

  // ← ahora con línea a ambos lados para que el centrado se vea simétrico
  &::before,
  &::after {
  content: '';
  display: inline-block;
  width: 2rem;
  height: 2px;
  background-color: $color-primary;
  border-radius: 2px;
  }
  }

  .destinations__title {
  font-size: 1.75rem;
  font-weight: $font-weight-bold;
  line-height: 1.2;
  color: $color-text-dark;
  text-align: center;       // ← añadido

  @include md { font-size: 1.875rem; }
  }

  .destinations__subtitle {
  width: 100%;
  max-width: 740px;
  font-size: $font-size-base;
  font-weight: $font-weight-medium;
  line-height: 1.5;
  letter-spacing: 0.2px;
  color: rgba(80, 80, 80, 0.87);
  text-align: center;       // ← era left
  }

  // ─── Grid principal ─────────────────────────────────────────────────────────
  .destinations__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2.5rem;

    @include md {
      grid-template-columns: 1fr 1fr;
    }
  }

  // ─── Sub-grid (3 tarjetas derechas) ─────────────────────────────────────────
  .destinations__subgrid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;

    @include sm {
      grid-template-columns: repeat(2, 1fr);
    }

    @include md {
      grid-template-rows: repeat(2, 1fr);
    }
  }

  // ─── Card base ──────────────────────────────────────────────────────────────
  .destinations__card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: $dest-radius;
    text-decoration: none;
    height: $dest-h-card-mobile;
    outline: none;
    transition:
      transform   0.25s ease,
      box-shadow  0.25s ease;

    @include sm { height: $dest-h-card-sm; }

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);

      .destinations__card-img  { transform: scale(1.06); }
      .destinations__card-overlay { opacity: 0.85; }
    }

    &:focus-visible {
      outline: 2px solid $color-primary;
      outline-offset: 3px;
      box-shadow: 0 0 0 4px rgba($color-primary, 0.2);
    }

    // ── Tarjeta principal (Arequipa) ───────────────────────────────────────
    &--featured {
      height: $dest-h-featured-mobile;

      @include sm { height: $dest-h-featured-sm; }
      @include md { height: $dest-h-featured-md; }
    }

    // ── Tarjeta ancha (Cusco, ocupa 2 columnas en sm) ─────────────────────
    &--wide {
      @include sm { grid-column: span 2; }
    }
  }

  // ─── Imagen ─────────────────────────────────────────────────────────────────
  .destinations__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  // ─── Overlay degradado ──────────────────────────────────────────────────────
  .destinations__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      $dest-overlay-from  0%,
      $dest-overlay-via   40%,
      transparent         100%
    );
    transition: opacity 0.3s ease;
  }

  // ─── Label del destino ──────────────────────────────────────────────────────
  .destinations__card-label {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    font-size: 1.5rem;
    font-weight: $font-weight-semibold;
    line-height: 1.2;
    color: $color-white;
    // ← sombra de texto para legibilidad sobre cualquier imagen
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    transition: transform 0.3s ease;

    // ← label sube levemente al hover de la card
    .destinations__card:hover & {
      transform: translateY(-3px);
    }

    // ── Variante pequeña (tarjetas del subgrid) ─────────────────────────
    &--sm {
      bottom: 1.5rem;
      left: 1.5rem;
      font-size: 1.25rem;
    }
  }
</style>
